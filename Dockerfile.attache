# SIRAL — service « Attaché de justice » (sidecar).
#
# Seul conteneur détenteur de la clé-maître et des clés déchiffrées : il relève
# la boîte dédiée, lance les runs Claude Code (abonnement, pas d'API) et sert
# l'API interne du panneau. Jamais publié sur Internet (réseau docker interne).
#
# Authentification Claude (une fois, après le premier démarrage) :
#   docker compose exec -it attache claude
#   (ou : claude setup-token sur une machine de confiance, puis coller le token)
# L'état de connexion persiste dans le volume claude-auth.
FROM node:20-bookworm-slim

# OCR de secours pour les PDF scannés (PV de motivation illisibles par
# extraction texte) : poppler (pdftoppm) rastérise, tesseract lit le français.
# Sans ces binaires, l'attaché signale simplement la pièce comme illisible.
RUN apt-get update \
  && apt-get install -y --no-install-recommends poppler-utils tesseract-ocr tesseract-ocr-fra \
  && rm -rf /var/lib/apt/lists/*

# Le CLI Claude Code — le « cerveau », connecté à l'abonnement du magistrat
RUN npm install -g @anthropic-ai/claude-code --no-audit --no-fund

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund
COPY scripts ./scripts
# Modules de calcul PARTAGÉS avec l'app web (source unique des règles de
# statistiques : lib/stats/*, lib/natinf/nataffRegles.mjs) — le service les
# importe en relatif depuis scripts/attache/.
COPY lib ./lib
# Référentiel NATINF embarqué (repli si aucun référentiel publié dans /data)
COPY data/natinf ./data/natinf

ENV NODE_ENV=production
ENV SIRAL_DATA_DIR=/data

# Le CLI a besoin d'un HOME inscriptible pour ~/.claude (volume claude-auth)
ENV HOME=/home/attache
RUN mkdir -p /home/attache /data

EXPOSE 8787
CMD ["node", "scripts/attache-service.mjs"]
