# SIRAL — configuration serveur. Copiez ce fichier vers `.env` puis remplissez.

# Votre nom de domaine (sans https://), ex : siral.exemple.fr
SIRAL_DOMAINE=

# Code d'enrôlement : requis pour créer un compte. Choisissez une valeur
# longue et aléatoire, communiquez-la oralement aux membres du service.
SIRAL_SETUP_CODE=

# Secret de signature des sessions (64 caractères aléatoires).
# Générer avec :  openssl rand -hex 32
SIRAL_SECRET=

# ────────────────────────────────────────────────────────────────────
# ATTACHÉ DE JUSTICE (IA) — optionnel, voir docs/ATTACHE.md
# Laisser SIRAL_ATTACHE_URL vide = fonctionnalité totalement absente.
# ────────────────────────────────────────────────────────────────────

# Adresse interne du service attaché (docker : http://attache:8787)
SIRAL_ATTACHE_URL=

# Clé-maître du service (64 hex) — enveloppe le trousseau de l'attaché au repos.
# Générer avec :  openssl rand -hex 32   (JAMAIS la même valeur que SIRAL_SECRET)
SIRAL_ATTACHE_MASTER_KEY=

# TJ et contentieux confiés (un seul de chaque)
SIRAL_ATTACHE_TJ=default
SIRAL_ATTACHE_CONTENTIEUX=crimorg

# VOTRE adresse pro — UNIQUE destinataire possible des mails de l'attaché
SIRAL_ATTACHE_OWNER_EMAIL=

# Boîte dédiée (ia@votre-domaine) — relève IMAP + envoi SMTP (OVH : ssl0.ovh.net)
SIRAL_ATTACHE_IMAP_HOST=
SIRAL_ATTACHE_IMAP_PORT=993
SIRAL_ATTACHE_IMAP_USER=
SIRAL_ATTACHE_IMAP_PASSWORD=
SIRAL_ATTACHE_SMTP_HOST=
SIRAL_ATTACHE_SMTP_PORT=465
SIRAL_ATTACHE_SMTP_USER=
SIRAL_ATTACHE_SMTP_PASSWORD=

# Fréquence de relève (minutes) et modèle Claude de secours (vide = défaut de
# l'abonnement). Le modèle et l'effort se choisissent depuis l'app (Paramètres →
# Attaché IA → Cerveau, ou le composer du chat) : ce réglage-ci ne sert que si
# rien n'est choisi dans l'app.
SIRAL_ATTACHE_POLL_MIN=5
SIRAL_ATTACHE_MODEL=

# Modèle dédié à l'analyse automatique des documents (extraction d'actes +
# chaîne légale) — tâche d'extraction, pas besoin d'Opus. Défaut : sonnet.
# Valeurs : sonnet | haiku | un identifiant de modèle complet.
SIRAL_ATTACHE_ANALYSE_MODEL=sonnet

# Heure du brief quotidien du majordome (0-23, heure serveur)
SIRAL_ATTACHE_BRIEFING_HOUR=6

# Apprentissage progressif (voir docs/ATTACHE.md) — valeurs par défaut saines.
# Budget de la mémoire consolidée en caractères (relue à chaque run : plus
# c'est court, moins chaque intervention coûte de jetons), nombre de signaux
# (corrections, refus ✗, retouches) qui déclenche une consolidation, et
# cadence de fond en jours.
SIRAL_ATTACHE_MEMOIRE_BUDGET=6000
SIRAL_ATTACHE_APPRENTISSAGE_SEUIL=12
SIRAL_ATTACHE_APPRENTISSAGE_JOURS=7

# Étude du corpus d'actes validés (zones Actes/DML → modèles « modele-* ») :
# nombre de nouveaux actes qui déclenche une étude, et cadence de fond en
# jours (ne tourne que s'il y a du nouveau).
SIRAL_ATTACHE_ETUDE_SEUIL=5
SIRAL_ATTACHE_ETUDE_JOURS=30

# Runs proactifs (mails transférés) traités de front (1-4). 1 = séquentiel
# strict (ancien comportement) ; 2 par défaut — monter selon la mémoire du
# serveur et le rythme du forfait.
SIRAL_ATTACHE_PROACTIVE_CONCURRENCY=2
