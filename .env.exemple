# SIRAL — configuration serveur. Copiez ce fichier vers `.env` puis remplissez.

# Votre nom de domaine (sans https://), ex : siral.exemple.fr
SIRAL_DOMAINE=

# Code d'enrôlement : requis pour créer un compte. Choisissez une valeur
# longue et aléatoire, communiquez-la oralement aux membres du service.
SIRAL_SETUP_CODE=

# Secret de signature des sessions (64 caractères aléatoires).
# Générer avec :  openssl rand -hex 32
SIRAL_SECRET=

# ────────────────────────────────────────────────────────────────────
# ATTACHÉ DE JUSTICE (IA) — optionnel, voir docs/ATTACHE.md
# Laisser SIRAL_ATTACHE_URL vide = fonctionnalité totalement absente.
# ────────────────────────────────────────────────────────────────────

# Adresse interne du service attaché (docker : http://attache:8787)
SIRAL_ATTACHE_URL=

# Clé-maître du service (64 hex) — enveloppe le trousseau de l'attaché au repos.
# Générer avec :  openssl rand -hex 32   (JAMAIS la même valeur que SIRAL_SECRET)
SIRAL_ATTACHE_MASTER_KEY=

# TJ et contentieux confiés (un seul de chaque)
SIRAL_ATTACHE_TJ=default
SIRAL_ATTACHE_CONTENTIEUX=crimorg

# VOTRE adresse pro — UNIQUE destinataire possible des mails de l'attaché
SIRAL_ATTACHE_OWNER_EMAIL=

# Boîte dédiée (ia@votre-domaine) — relève IMAP + envoi SMTP (OVH : ssl0.ovh.net)
SIRAL_ATTACHE_IMAP_HOST=
SIRAL_ATTACHE_IMAP_PORT=993
SIRAL_ATTACHE_IMAP_USER=
SIRAL_ATTACHE_IMAP_PASSWORD=
SIRAL_ATTACHE_SMTP_HOST=
SIRAL_ATTACHE_SMTP_PORT=465
SIRAL_ATTACHE_SMTP_USER=
SIRAL_ATTACHE_SMTP_PASSWORD=

# Fréquence de relève (minutes) et modèle Claude (vide = défaut de l'abonnement)
SIRAL_ATTACHE_POLL_MIN=5
SIRAL_ATTACHE_MODEL=
