# SIRAL — configuration serveur. Copiez ce fichier vers `.env` puis remplissez.

# Votre nom de domaine (sans https://), ex : siral.exemple.fr
SIRAL_DOMAINE=

# Code d'enrôlement : requis pour créer un compte. Choisissez une valeur
# longue et aléatoire, communiquez-la oralement aux membres du service.
SIRAL_SETUP_CODE=

# Secret de signature des sessions (64 caractères aléatoires).
# Générer avec :  openssl rand -hex 32
SIRAL_SECRET=

# ────────────────────────────────────────────────────────────────────
# ATTACHÉ DE JUSTICE (IA) — optionnel, voir docs/ATTACHE.md
# Laisser SIRAL_ATTACHE_URL vide = fonctionnalité totalement absente.
# ────────────────────────────────────────────────────────────────────

# Adresse interne du service attaché (docker : http://attache:8787)
SIRAL_ATTACHE_URL=

# Clé-maître du service (64 hex) — enveloppe le trousseau de l'attaché au repos.
# Générer avec :  openssl rand -hex 32   (JAMAIS la même valeur que SIRAL_SECRET)
SIRAL_ATTACHE_MASTER_KEY=

# TJ et contentieux confiés (un seul de chaque)
SIRAL_ATTACHE_TJ=default
SIRAL_ATTACHE_CONTENTIEUX=crimorg

# VOTRE adresse pro — UNIQUE destinataire possible des mails de l'attaché,
# et SEUL expéditeur autorisé à lui donner des consignes (le corps d'un
# transfert vaut instruction : tout autre expéditeur est ignoré, audité et
# signalé au fil). Adresses supplémentaires autorisées (secrétariat…) :
# SIRAL_ATTACHE_ALLOWED_SENDERS, séparées par des virgules. Les DEUX vides =
# filtre inactif (à réserver à une boîte réellement privée).
SIRAL_ATTACHE_OWNER_EMAIL=
SIRAL_ATTACHE_ALLOWED_SENDERS=

# Boîte dédiée (ia@votre-domaine) — relève IMAP + envoi SMTP (OVH : ssl0.ovh.net)
SIRAL_ATTACHE_IMAP_HOST=
SIRAL_ATTACHE_IMAP_PORT=993
SIRAL_ATTACHE_IMAP_USER=
SIRAL_ATTACHE_IMAP_PASSWORD=
SIRAL_ATTACHE_SMTP_HOST=
SIRAL_ATTACHE_SMTP_PORT=465
SIRAL_ATTACHE_SMTP_USER=
SIRAL_ATTACHE_SMTP_PASSWORD=

# Fréquence de relève (minutes) et modèle Claude de secours (vide = défaut de
# l'abonnement). Le modèle et l'effort se choisissent depuis l'app (Paramètres →
# Attaché IA → Cerveau, ou le composer du chat) : ce réglage-ci ne sert que si
# rien n'est choisi dans l'app.
SIRAL_ATTACHE_POLL_MIN=5
SIRAL_ATTACHE_MODEL=

# Reprises d'un mail dont le traitement a échoué : nombre total de tentatives
# (défaut 3, max 6) espacées d'un délai croissant (base en minutes, défaut 10 :
# 10, 20, 40 min…). Reprises épuisées = carte d'alerte au fil, plus de retry
# automatique (le bouton « relever » du panneau redonne une chance).
SIRAL_ATTACHE_MAIL_MAX_ATTEMPTS=3
SIRAL_ATTACHE_MAIL_RETRY_MIN=10

# Modèle dédié à l'analyse automatique des documents (extraction d'actes +
# chaîne légale) — tâche d'extraction, pas besoin d'Opus. Défaut : sonnet.
# Valeurs : sonnet | haiku | un identifiant de modèle complet.
SIRAL_ATTACHE_ANALYSE_MODEL=sonnet

# Heure du brief quotidien du majordome (0-23, heure serveur)
SIRAL_ATTACHE_BRIEFING_HOUR=6

# Apprentissage progressif (voir docs/ATTACHE.md) — valeurs par défaut saines.
# Budget de la mémoire consolidée en caractères (relue à chaque run : plus
# c'est court, moins chaque intervention coûte de jetons), nombre de signaux
# (corrections, refus ✗, retouches) qui déclenche une consolidation, et
# cadence de fond en jours.
SIRAL_ATTACHE_MEMOIRE_BUDGET=6000
SIRAL_ATTACHE_APPRENTISSAGE_SEUIL=12
SIRAL_ATTACHE_APPRENTISSAGE_JOURS=7
# Corrections DIRECTES du magistrat (acte corrigé à la main, proposition
# refusée ✗, reprise en chat) : signaux « forts » qui consolident sans
# attendre le seuil ni la cadence, pour ne pas refaire l'erreur au prochain
# acte (anti-rafale de 12 h conservé).
SIRAL_ATTACHE_APPRENTISSAGE_SEUIL_FORTS=3

# Étude du corpus d'actes validés (zones Actes/DML → modèles « modele-* ») :
# nombre de nouveaux actes qui déclenche une étude, et cadence de fond en
# jours (ne tourne que s'il y a du nouveau).
SIRAL_ATTACHE_ETUDE_SEUIL=5
SIRAL_ATTACHE_ETUDE_JOURS=30

# Actualisation automatique de la description des dossiers (en arrière-plan, à
# chaque CR rédigé ou acte/document téléversé — voir docs/ATTACHE.md). Période
# de calme en minutes avant de tirer (fusionne les ajouts en rafale) et
# intervalle minimum en minutes entre deux actualisations d'un MÊME dossier
# (anti-rafale). Un seul dossier est actualisé par relève, en modèle économe.
SIRAL_ATTACHE_DESC_QUIET_MIN=3
SIRAL_ATTACHE_DESC_MIN_INTERVAL_MIN=20

# Plafond de skills « auto-* » (créées par l'attaché en consolidation) : la
# liste des skills est relue à chaque run — au-delà, il doit fusionner avant
# de créer (imposé dans le code).
SIRAL_ATTACHE_AUTO_SKILLS_MAX=12

# Runs proactifs (mails transférés) traités de front (1-4). 1 = séquentiel
# strict (ancien comportement) ; 2 par défaut — monter selon la mémoire du
# serveur et le rythme du forfait.
SIRAL_ATTACHE_PROACTIVE_CONCURRENCY=2

# Sous-agents (lots parallèles) — le PREMIER poste de dépense. Concurrence,
# tours max par sous-agent (resserré de 15 à 10 : la lecture seule sature en
# quelques tours, chaque tour renvoie le contexte), timeout par tâche.
SIRAL_ATTACHE_SUBAGENT_CONCURRENCY=3
SIRAL_ATTACHE_SUBAGENT_MAX_TURNS=10
SIRAL_ATTACHE_SUBAGENT_TIMEOUT_MIN=8

# Gouverneur de consommation (« juguler ») — bride AUTOMATIQUEMENT le forfait
# sans réglage : au-delà du 1er seuil de la fenêtre de 5 h, les lots de
# sous-agents des runs de FOND passent d'office en régime économe ; au-delà du
# 2nd, les runs autonomes (brief, étude, consolidation, routines) sont différés.
# Le chat et le traitement des mails (rédaction d'actes, priorité n°1) ne sont
# JAMAIS bridés ni différés. Fractions du plafond (config.cap5h / capHebdo).
# Inerte tant qu'aucun plafond de forfait n'est renseigné dans l'app.
SIRAL_ATTACHE_BUDGET_SERRER_5H=0.75
SIRAL_ATTACHE_BUDGET_STOP_5H=1.0
SIRAL_ATTACHE_BUDGET_SERRER_7J=0.85
SIRAL_ATTACHE_BUDGET_STOP_7J=1.0

# Fenêtre de NUIT (heure serveur) réservée aux travaux de FOND lourds — étude
# du corpus d'actes et consolidation de l'apprentissage : ils ne tournent qu'à
# ces heures, jamais pendant la journée de travail, pour laisser tout le forfait
# aux demandes et aux mails du magistrat. Repli 22 h → 7 h. Pour tout autoriser
# à toute heure, mettre début = fin. Les déclenchements MANUELS (boutons du
# panneau) restent possibles à tout moment.
SIRAL_ATTACHE_NIGHT_START=22
SIRAL_ATTACHE_NIGHT_END=7
