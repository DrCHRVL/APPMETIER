# SIRAL — configuration serveur. Copiez ce fichier vers `.env` puis remplissez.

# Votre nom de domaine (sans https://), ex : siral.exemple.fr
SIRAL_DOMAINE=

# Code d'enrôlement : requis pour créer un compte. Choisissez une valeur
# longue et aléatoire, communiquez-la oralement aux membres du service.
SIRAL_SETUP_CODE=

# Secret de signature des sessions (64 caractères aléatoires).
# Générer avec :  openssl rand -hex 32
SIRAL_SECRET=
